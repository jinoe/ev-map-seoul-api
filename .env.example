PROJECT_NAME=EV Map Seoul API
VERSION=0.1.0
API_V1_STR=/api/v1
PORT=400
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# "server" → localhost MongoDB (서버에서 실행)
# "local"  → 13.125.235.209 AWS MongoDB (로컬 개발)
APP_ENV=local

# MongoDB 설정
# MONGODB_URI 를 직접 지정하면 APP_ENV 기반 자동 선택보다 우선합니다
MONGODB_URI=
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_PORT=27017
MONGODB_DB_NAME=ev_charger
